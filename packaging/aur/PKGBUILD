# Maintainer: iaragon maintainers <https://github.com/jeffersonguerin/iaragon>
#
# AUR package for iaragon — a bidirectional Google Drive sync daemon.
#
# A VCS (-git) package: the project is a rolling release with no version
# tags, so pkgver() derives a monotone version from git. Unlike the .deb/.rpm
# (which bundle their own BEAM runtime), the Arch package builds from source
# and DEPENDS on the distro `erlang` — idiomatic for a rolling distro, and
# strictly better here: the daemon inherits OTP security updates through
# pacman instead of carrying a frozen runtime.
pkgname=iaragon-git
_pkgname=iaragon
pkgver=0
pkgrel=1
pkgdesc="Bidirectional Google Drive sync daemon (Mirror mode) for Linux"
arch=('x86_64' 'aarch64')
url="https://github.com/jeffersonguerin/iaragon"
license=('Apache')
# erlang >= 29 at runtime (Arch tracks current OTP); gleam+rebar3+gcc to build
# (rebar3 compiles the Erlang dep behind filespy, gcc the sqlight NIF).
depends=('erlang>=29')
makedepends=('git' 'gleam' 'rebar3' 'gcc' 'make')
optdepends=('inotify-tools: instant local-change detection (else polling)')
provides=('iaragon')
conflicts=('iaragon')
source=("$_pkgname::git+https://github.com/jeffersonguerin/iaragon.git#branch=main")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$_pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$srcdir/$_pkgname"
  gleam export erlang-shipment
}

package() {
  cd "$srcdir/$_pkgname"
  local lib="$pkgdir/usr/lib/$_pkgname"
  install -d "$lib" "$pkgdir/usr/bin" "$pkgdir/usr/lib/systemd/user"

  # The compiled shipment (entrypoint.sh + every dep's ebin/priv).
  cp -a build/erlang-shipment/. "$lib/"

  # Launchers over the shipment; on Arch, erl is on PATH from the erlang pkg.
  cat > "$pkgdir/usr/bin/iaragon" <<'EOF'
#!/bin/sh
exec /usr/lib/iaragon/entrypoint.sh run "$@"
EOF
  cat > "$pkgdir/usr/bin/iaragon-login" <<'EOF'
#!/bin/sh
exec erl -pa /usr/lib/iaragon/*/ebin -noshell -eval 'iaragon@login:main(), halt(0)' -extra "$@"
EOF
  cat > "$pkgdir/usr/bin/iaragon-doctor" <<'EOF'
#!/bin/sh
exec erl -pa /usr/lib/iaragon/*/ebin -noshell -eval 'iaragon@doctor:main(), halt(0)' -extra "$@"
EOF
  chmod 0755 "$pkgdir/usr/bin/iaragon" "$pkgdir/usr/bin/iaragon-login" "$pkgdir/usr/bin/iaragon-doctor"

  # systemd USER units (system-provided; each user runs `systemctl --user enable`).
  install -Dm644 dist/iaragon.service        "$pkgdir/usr/lib/systemd/user/iaragon.service"
  install -Dm644 dist/iaragon-doctor.service "$pkgdir/usr/lib/systemd/user/iaragon-doctor.service"
  install -Dm644 dist/iaragon-doctor.timer   "$pkgdir/usr/lib/systemd/user/iaragon-doctor.timer"
  # The versioned unit points ExecStart at %h/.local/bin; rewrite to the
  # packaged /usr/bin path.
  sed -i 's#%h/.local/bin/iaragon#/usr/bin/iaragon#' "$pkgdir/usr/lib/systemd/user/iaragon.service"

  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
