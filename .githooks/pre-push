#!/bin/sh
# Local CI, push gate. Four checks (cheapest first) and a version step:
#
#  1. Warnings gate (always). Nothing leaves the machine with compiler
#     warnings. The compiler is the linter in Gleam (there is no external
#     one): unused imports/variables, deprecations and the like arrive as
#     warnings — and they re-emit even for cached modules, so a warning
#     cannot hide behind an incremental build.
#
#  2. FFI warnings gate (always). Gate 1 only promotes GLEAM warnings:
#     warnings the Erlang compiler raises on the FFI sources are printed
#     but `gleam build --warnings-as-errors` still exits 0 (verified on
#     OTP 29 with the deprecated-catch warning — it sailed through). So the
#     project's own .erl files are compiled again, directly with
#     `erlc +warnings_as_errors`, which does refuse them. Scoped to OUR
#     sources only: a dependency's warnings are upstream's to fix, not a
#     reason to block this repo's pushes (known instance: fs_server.erl's
#     deprecated catch — fixed on synrc/fs master, no Hex release yet).
#
#  3. Release gate (only when relevant). If this push changes anything that
#     feeds the self-contained release (src/, gleam.toml, manifest.toml, or
#     the release builder), build that release and smoke-test that the
#     bundle runs on its OWN bundled OTP. This keeps the promise that `main`
#     always ships a download that actually runs — without taxing a
#     docs-only push, which skips it. The build is heavy (~80s + a copy of
#     the OTP tree), which is exactly why it is gated on relevance.
#
#  4. Tray gate (only when relevant). If this push changes the Rust tray
#     crate (integrations/tray/), run its tests. Skipped with a warning when
#     cargo is absent — Rust is an optional component toolchain.
#
#  5. Version bump (only for a main update, after every gate passed). Each
#     push that updates main gets the next odometer version tag — see
#     next_version() for the wheel rules and the patch-vs-minor criterion.
#
# Living here (not in pre-commit) keeps the commit cycle cheap; the
# pre-commit hook still guards formatting and the suite.
# Bypass for emergencies: git push --no-verify.
set -eu

# Odometer versioning. The wheels: patch counts 0-9, minor 0-99; a bump past
# a wheel's limit carries into the next one (0.5.9 +patch -> 0.6.0;
# 0.99.9 +patch -> 1.0.0; 1.99.3 +minor -> 2.0.0). The major NEVER moves on
# its own — only by carry: in a rolling release the version is a mileage
# counter, not a compatibility promise. Which wheel turns is mechanical:
# a push that changes src/ (daemon behavior) is a MINOR bump; anything else
# (docs, tests, scripts, packaging, hooks) is a PATCH.
next_version() {
  version="$1"
  kind="$2"
  major="${version%%.*}"
  rest="${version#*.}"
  minor="${rest%%.*}"
  patch="${rest#*.}"
  case "$kind" in
    patch)
      patch=$((patch + 1))
      if [ "$patch" -gt 9 ]; then
        patch=0
        minor=$((minor + 1))
      fi
      ;;
    minor)
      minor=$((minor + 1))
      patch=0
      ;;
    *)
      echo "next_version: unknown bump kind '$kind'" >&2
      return 1
      ;;
  esac
  if [ "$minor" -gt 99 ]; then
    minor=0
    major=$((major + 1))
  fi
  echo "$major.$minor.$patch"
}

# Self-test mode so the wheel arithmetic is checkable without a push:
#   .githooks/pre-push --next-version 0.99.9 patch   ->  1.0.0
if [ "${1:-}" = "--next-version" ]; then
  next_version "$2" "$3"
  exit $?
fi

if ! command -v gleam >/dev/null 2>&1; then
  echo "pre-push: 'gleam' not found in PATH." >&2
  echo "pre-push: this project needs Gleam + Erlang/OTP >= 29 (see README)." >&2
  exit 1
fi

# --- 1. warnings gate (always) ---------------------------------------------
echo "pre-push: gleam build --warnings-as-errors"
if ! gleam build --warnings-as-errors; then
  echo "pre-push: build has warnings — push refused." >&2
  exit 1
fi

# --- 2. FFI warnings gate (always) -----------------------------------------
# Only the project's own .erl files; module filenames never contain spaces,
# so the unquoted expansion below is safe.
echo "pre-push: erlc +warnings_as_errors (FFI sources)"
erl_srcs="$(find src test -maxdepth 1 -name '*.erl' 2>/dev/null)"
if [ -n "$erl_srcs" ]; then
  erl_tmp="$(mktemp -d)"
  if ! erlc +warnings_as_errors -o "$erl_tmp" $erl_srcs; then
    rm -rf "$erl_tmp"
    echo "pre-push: Erlang FFI sources have warnings — push refused." >&2
    exit 1
  fi
  rm -rf "$erl_tmp"
fi

# --- 3. release gate (only when release-relevant files changed) ------------
# Read the pushed ref lines git feeds on stdin and decide whether any commit
# in this push touches the release inputs. When the range cannot be resolved
# (new branch with no known base, unreadable input), fail SAFE toward running
# the check rather than skipping it.
STDIN="$(cat)"

# A push carrying only tags (notably the version tag step 5 itself pushes)
# must not re-run the content gates: they already ran for the commits those
# tags point at. Branch updates are what the gates guard.
if ! printf '%s\n' "$STDIN" | grep -q 'refs/heads/'; then
  exit 0
fi

# Does any commit in this push touch a path matching $1 (an ERE)? Echoes
# "yes" when so, or when the range can't be resolved (fail safe toward
# running the check). Fed by a here-doc (NOT a pipe) so the loop runs in this
# shell — a piped `while` would run in a subshell and lose `had_line`/`return`.
push_touches() {
  pattern="$1"
  had_line=0
  while read -r _local_ref local_sha _remote_ref remote_sha; do
    [ -n "${local_sha:-}" ] || continue
    case "$local_sha" in *[!0]*) : ;; *) continue ;; esac   # all-zero local = delete
    had_line=1
    case "$remote_sha" in
      *[!0]*) range="$remote_sha..$local_sha" ;;            # updating an existing ref
      *)                                                     # new ref: base off origin/main
        if base="$(git merge-base "$local_sha" origin/main 2>/dev/null)"; then
          range="$base..$local_sha"
        else
          echo yes; return                                   # no base — validate to be safe
        fi ;;
    esac
    # Distinguish "diff ran and matched nothing" from "diff FAILED" (e.g. the
    # remote sha is not present locally after a remote-side move): a failed
    # diff must fail SAFE toward running the check, not silently skip it.
    if ! changed="$(git diff --name-only "$range" 2>/dev/null)"; then
      echo yes; return
    fi
    if printf '%s\n' "$changed" | grep -Eq "$pattern"; then
      echo yes; return
    fi
  done <<EOF
$STDIN
EOF
  # If we saw no usable ref line at all, validate to be safe.
  [ "$had_line" = 1 ] || echo yes
}

if [ -n "$(push_touches '^(src/|gleam\.toml$|manifest\.toml$|scripts/build-release\.sh$)')" ]; then
  echo "pre-push: release inputs changed — building the self-contained release"
  out="$(mktemp -d)"
  home="$(mktemp -d)"
  trap 'rm -rf "$out" "$home"' EXIT
  if ! ./scripts/build-release.sh "$out" >"$out/build.log" 2>&1; then
    echo "pre-push: self-contained release failed to build — push refused." >&2
    tail -20 "$out/build.log" >&2 || true
    exit 1
  fi
  rel=""
  for d in "$out"/iaragon-*/; do
    [ -d "$d" ] && { rel="$d"; break; }
  done
  if [ -z "$rel" ] || [ ! -x "${rel}bin/iaragon-login" ]; then
    echo "pre-push: release build produced no runnable bundle — push refused." >&2
    exit 1
  fi
  # Smoke: the bundle must run on its OWN OTP. iaragon-login with no client
  # configured prints the assisted-setup text and exits 0 — a clean success
  # signal that the BEAM booted from the bundle and the app loaded.
  if ! HOME="$home" "${rel}bin/iaragon-login" >/dev/null 2>&1; then
    echo "pre-push: the built bundle does not run (login smoke failed) — push refused." >&2
    exit 1
  fi
  echo "pre-push: self-contained release builds and runs."
fi

# --- 4. tray gate (only when the Rust tray changed) ------------------------
# The tray is a separate Rust crate; keep it green the same way. If cargo is
# absent we only warn — Rust is an optional component toolchain, not required
# to work on the daemon.
if [ -n "$(push_touches '^integrations/tray/')" ]; then
  if command -v cargo >/dev/null 2>&1; then
    echo "pre-push: cargo test (integrations/tray)"
    if ! ( cd integrations/tray && cargo test --quiet ); then
      echo "pre-push: tray tests failed — push refused." >&2
      exit 1
    fi
  else
    echo "pre-push: cargo not found — skipping the tray tests (install Rust to gate them)." >&2
  fi
fi

# --- 5. version bump (only for a main update, after every gate passed) ------
# The pushed main commit gets the next odometer tag, pushed alongside with
# --no-verify (its content just passed the gates above; re-entering the hook
# for the tag would be circular). Idempotent: a re-push of an already-tagged
# commit mints nothing. Known edge, accepted: if the branch push is rejected
# after the hook (e.g. non-fast-forward), the tag has already landed and
# points at a commit not yet on main — harmless, and the next successful
# push continues from the highest tag either way.
main_sha=""
while read -r _local_ref local_sha remote_ref _remote_sha; do
  [ "$remote_ref" = "refs/heads/main" ] || continue
  case "$local_sha" in *[!0]*) main_sha="$local_sha" ;; *) : ;; esac
done <<STDIN_EOF
$STDIN
STDIN_EOF

if [ -n "$main_sha" ]; then
  already="$(git tag --points-at "$main_sha" --list 'v[0-9]*' | head -1)"
  if [ -n "$already" ]; then
    echo "pre-push: $already already versions this commit"
  else
    current="$(git tag --list 'v[0-9]*' | sed 's/^v//' \
      | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1)"
    if [ -z "$current" ]; then
      next="1.0.0"
      kind="first"
    else
      # push_touches errs toward "yes" when a range cannot be resolved —
      # here that caution lands on minor, the larger wheel: acceptable.
      if [ -n "$(push_touches '^src/')" ]; then kind="minor"; else kind="patch"; fi
      next="$(next_version "$current" "$kind")"
    fi
    git tag -a "v$next" -m "iaragon $next ($kind bump, automated by pre-push)" "$main_sha"
    if git push --no-verify --quiet origin "refs/tags/v$next"; then
      echo "pre-push: versioned as v$next ($kind)"
    else
      # The tag exists locally either way; a later push carries it. Never
      # fail the branch push over version bookkeeping.
      echo "pre-push: warning: could not push tag v$next (kept locally)" >&2
    fi
  fi

  # Channel pointers, MOVING tags — never versions themselves (the vX.Y.Z
  # tags are the immutable history). Forced on purpose: moving is their
  # semantics; consumers refreshing them need `git fetch --tags --force`.
  #
  # latest: the newest main commit — deliberately the SAME name as the
  # rolling release install.sh consumes, so "latest" means one thing
  # everywhere. The release ASSET under that name only refreshes when the
  # maintainer runs publish-release.sh: between pushes the tag is ahead of
  # the published bundle, and that lag is accepted and documented.
  git tag -f latest "$main_sha" >/dev/null
  if git push --no-verify --quiet --force origin refs/tags/latest; then
    echo "pre-push: latest -> $(git rev-parse --short "$main_sha")"
  else
    echo "pre-push: warning: could not move the latest tag (kept locally)" >&2
  fi

  # stable: wherever the Formula's pinned tag points — the Formula is the
  # source of truth for the stable channel, and this keeps the named
  # pointer aligned with it mechanically (move the pin, the next push
  # moves the tag).
  pinned="$(git show "$main_sha:Formula/iaragon.rb" 2>/dev/null \
    | sed -n 's#.*refs/tags/\(v[0-9][0-9.]*\)\.tar\.gz.*#\1#p' | head -1)"
  if [ -n "$pinned" ] && pinned_sha="$(git rev-parse --verify --quiet "$pinned^{commit}")"; then
    git tag -f stable "$pinned_sha" >/dev/null
    if git push --no-verify --quiet --force origin refs/tags/stable; then
      echo "pre-push: stable -> $pinned ($(git rev-parse --short "$pinned_sha"))"
    else
      echo "pre-push: warning: could not move the stable tag (kept locally)" >&2
    fi
  else
    echo "pre-push: warning: no formula stable pin found — stable tag not moved" >&2
  fi
fi
